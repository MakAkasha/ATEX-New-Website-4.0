NODE_ENV=production
HOST=127.0.0.1
PORT=5173

# Required in production (min 16 chars)
SESSION_SECRET=change-this-to-a-long-random-secret
SESSION_NAME=atex.sid
SESSION_COOKIE_SECURE=true
SESSION_SAME_SITE=lax
SESSION_MAX_AGE_MS=43200000
TRUST_PROXY=true

# Optional tuning
ENABLE_REQUEST_LOGS=true
GLOBAL_RATE_LIMIT_WINDOW_MS=60000
GLOBAL_RATE_LIMIT_LIMIT=300
CONTACT_RATE_LIMIT_WINDOW_MS=60000
CONTACT_RATE_LIMIT_LIMIT=20
CONTACT_EMAIL_FORWARD_ENABLED=true
CONTACT_EMAIL_TO=atexksa.iot@gmail.com
CSP_REPORT_ONLY=false

# Analytics (optional)
ANALYTICS_ENABLED=false
GA_MEASUREMENT_ID=
GTM_CONTAINER_ID=

# Optional DB override
DB_PATH=

# Optional bootstrap admin (only used when admins table is empty)
DEFAULT_ADMIN_ENABLED=false
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=change-me-now
