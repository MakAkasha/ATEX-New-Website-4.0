<footer class="footer">
  <% const __homeContent = (typeof content !== 'undefined') ? content : null; %>
  <div class="container footer__inner">
    <div class="footer__col footer__col--brand">
      <a class="footer__brandLogo" href="/" aria-label="ATEX">
        <img src="/assets/ATEX-footer-logo.svg" alt="ATEX" />
      </a>
      <p class="footer__desc">شركة سعودية متخصصة في حلول إنترنت الأشياء للشركات.</p>
      <p class="muted"><%= (__homeContent?.contact?.address || 'جدة، المملكة العربية السعودية') %></p>
    </div>
    <div class="footer__col">
      <h3 class="footer__title">روابط سريعة</h3>
      <div class="footer__links">
        <a class="footer__link" href="/">الرئيسية</a>
        <a class="footer__link" href="/#solutions">الحلول والخدمات</a>
        <a class="footer__link" href="/blog">المدونة</a>
        <a class="footer__link" href="/#contact">تواصل معنا</a>
      </div>
    </div>
    <div class="footer__col">
      <h3 class="footer__title">تواصل</h3>
      <div class="footer__links">
        <a class="footer__link" href="mailto:<%= (__homeContent?.contact?.email || 'contact@atex.sa') %>"><%= (__homeContent?.contact?.email || 'contact@atex.sa') %></a>
        <a class="footer__link footer__phone" href="tel:0580102121">خدمة العملاء : 0580102121</a>
        <a class="footer__link footer__phone" href="tel:0509330008">المبيعات : 0509330008</a>
      </div>
    </div>
  </div>
  <div class="footer__bottom">
    <div class="container footer__bottomInner">
      <span>© 2026 ATEX. All Rights Reserved</span>
      <div class="footer__legal">
        <a class="footer__link" href="/privacy">Privacy Policy</a>
        <a class="footer__link" href="/terms">Terms</a>
      </div>
    </div>
  </div>
</footer>

<!-- GSAP -->
<script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/ScrollTrigger.min.js"></script>
<script src="/assets/js/consent.js"></script>
<script type="module" src="/assets/js/main.js"></script>
