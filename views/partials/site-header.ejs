<!-- Top bar -->
<% const __homeContent = (typeof content !== 'undefined') ? content : null; %>
<% const __topbarPhone = '+966580102121'; %>
<% const __topbarWhatsapp = 'https://wa.me/966580102121'; %>
<div class="topbar">
  <div class="container topbar__inner">
    <div class="topbar__item">
      <span>
        <%= (__homeContent?.topbar?.supportText || 'الدعم والمبيعات:') %>
        <a href="<%= __topbarWhatsapp %>" target="_blank" rel="noopener noreferrer" dir="ltr"><strong><%= __topbarPhone %></strong></a>
      </span>
    </div>
    <div class="topbar__item">
      <span><%= (__homeContent?.topbar?.tagline || 'حلول إنترنت الأشياء') %></span>
      <a class="topbar__textLink" href="https://portal.atex-ksa.com" target="_blank" rel="noopener noreferrer">
        <span>بوابة العملاء</span>
        <span class="topbar__extIcon" aria-hidden="true">↗</span>
      </a>
    </div>
  </div>
</div>

<!-- Navbar -->
<header class="header" id="home">
  <div class="container header__inner">
    <!-- Brand + nav grouped on RIGHT -->
    <a class="brand" href="/" aria-label="الانتقال إلى الرئيسية">
      <img class="brand__logoImg" src="/assets/ATEX-logo.svg" alt="ATEX" />
    </a>

    <nav class="nav" aria-label="التنقّل الرئيسي">
      <div class="nav__backdrop" data-nav-backdrop aria-hidden="true"></div>
      <button
        class="nav__toggle"
        type="button"
        aria-label="فتح القائمة"
        aria-expanded="false"
        aria-controls="navMenu">
        <span class="nav__toggleLines" aria-hidden="true"></span>
      </button>

      <div class="nav__menu" id="navMenu">
        <a class="nav__link" data-route href="/">الرئيسية</a>
        <a class="nav__link" data-route href="/solutions">الأنظمة والحلول</a>
        <a class="nav__link" data-route href="/blog">المدونة</a>
        <a class="nav__link" data-route href="/contact-us">تواصل معنا</a>
        <a class="btn btn--primary btn--small" href="https://portal.atex-ksa.com" target="_blank" rel="noopener noreferrer" dir="rtl">
          <span class="nav__extIcon" aria-hidden="true">↗</span>
          <span>بوابة العملاء</span>
        </a>
      </div>
    </nav>
  </div>
</header>
