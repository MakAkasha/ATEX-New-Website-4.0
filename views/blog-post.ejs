<!doctype html>
<html lang="ar" dir="rtl">
  <head>
    <%- include('partials/head', { meta }) %>
    <style>
      .page { padding: 44px 0 70px; }
      .post { border: 1px solid rgba(0,0,0,0.08); border-radius: 18px; background: rgba(255,255,255,0.8); box-shadow: 0 10px 24px rgba(0,0,0,0.06); padding: 18px; }
      .post h1 { margin: 0 0 8px; font-weight: 900; }
      .post .meta { color: rgba(11,31,42,0.72); font-weight: 800; font-size: 13px; margin-bottom: 12px; }
      .post .cover { border-radius: 16px; overflow:hidden; border:1px solid rgba(0,0,0,0.08); background:#eef2f6; margin-bottom: 14px; }
      .post .cover img { width:100%; height: 340px; object-fit: cover; display:block; }
      .post .content { font-weight: 700; color: rgba(11,31,42,0.88); }
      .post .content img { max-width:100%; height:auto; border-radius: 12px; }
      .post .content a { text-decoration: underline; }
    </style>
  </head>
  <body>
    <%- include('partials/site-header') %>
    <main class="page">
      <div class="container">
        <div class="post">
          <h1><%= post.title %></h1>
          <div class="meta" dir="ltr"><%= post.created_at %></div>
          <% if (post.cover_image) { %>
            <div class="cover"><img src="<%= post.cover_image %>" alt="<%= post.title %>" /></div>
          <% } %>
          <div class="content"><%- post.content_html %></div>
          <div style="margin-top:14px">
            <a class="btn btn--ghost btn--small" href="/blog">رجوع للمدونة</a>
          </div>
        </div>
      </div>
    </main>
    <%- include('partials/site-footer') %>
  </body>
</html>
