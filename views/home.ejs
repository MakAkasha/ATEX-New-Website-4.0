<!doctype html>
<html lang="ar" dir="rtl">
  <head>
    <%- include('partials/head', { meta }) %>
  </head>

  <body>
    <%- include('partials/site-header') %>

    <% 
      const __heroVideoCfg = content?.heroVideo || {};
      const __heroVideoSourceType = __heroVideoCfg.sourceType === 'upload' ? 'upload' : 'youtube';
      const __heroVideoYoutubeUrl = __heroVideoCfg.youtubeUrl || 'https://www.youtube.com/watch?v=xwYbULh3aRE';
      const __heroVideoUploadedUrl = __heroVideoCfg.uploadedVideoUrl || '';
      function __extractYouTubeId(url){
        if (!url) return '';
        const s = String(url).trim();
        const m1 = s.match(/[?&]v=([a-zA-Z0-9_-]{11})/);
        if (m1) return m1[1];
        const m2 = s.match(/youtu\.be\/([a-zA-Z0-9_-]{11})/);
        if (m2) return m2[1];
        const m3 = s.match(/youtube\.com\/embed\/([a-zA-Z0-9_-]{11})/);
        if (m3) return m3[1];
        return '';
      }
      const __heroVideoYoutubeId = __extractYouTubeId(__heroVideoYoutubeUrl);
    %>

    <main>
      <!-- Hero (Video Loop) -->
      <section class="heroVideo" aria-label="IoT Hero">
        <div class="heroVideo__media" aria-hidden="true">
          <% if (__heroVideoSourceType === 'upload' && __heroVideoUploadedUrl) { %>
            <video autoplay muted loop playsinline preload="metadata">
              <source src="<%= __heroVideoUploadedUrl %>" type="video/mp4" />
            </video>
          <% } else if (__heroVideoYoutubeId) { %>
            <iframe
              src="https://www.youtube-nocookie.com/embed/<%= __heroVideoYoutubeId %>?autoplay=1&mute=1&controls=0&loop=1&playlist=<%= __heroVideoYoutubeId %>&rel=0&playsinline=1&iv_load_policy=3&disablekb=1&fs=0"
              title="IoT background video"
              frameborder="0"
              allow="autoplay; encrypted-media; picture-in-picture"
              referrerpolicy="strict-origin-when-cross-origin"
              allowfullscreen></iframe>
          <% } else { %>
            <video autoplay muted loop playsinline preload="metadata">
              <source src="https://cdn.coverr.co/videos/coverr-smart-city-overview-1579/1080p.mp4" type="video/mp4" />
            </video>
          <% } %>
        </div>
        <div class="container heroVideo__inner">
          <div class="heroVideo__content">
            <p class="heroVideo__kicker">IoT Solutions</p>
            <h2 class="heroVideo__title">حلول إنترنت الأشياء للشركات</h2>
            <p class="heroVideo__desc">من الأجهزة والاتصال إلى التحليلات ولوحات المتابعة في تجربة موحدة وسريعة.</p>
            <a class="btn btn--primary" href="#contact">ابدأ مشروعك الآن</a>
          </div>
        </div>
      </section>

      <!-- Trust strip -->
      <section class="trustStrip" aria-label="مؤشرات الثقة">
        <div class="container trustStrip__inner">
          <article class="trustStrip__item" data-tilt>
            <span class="trustStrip__icon" aria-hidden="true">
              <lord-icon class="icon-lord" src="https://cdn.lordicon.com/msoeawqm.json" trigger="hover" colors="primary:#002b44,secondary:#ff9933"></lord-icon>
            </span>
            <strong>+43</strong>
            <span>مشروع تم تنفيذه بنجاح</span>
          </article>

          <article class="trustStrip__item" data-tilt>
            <span class="trustStrip__icon" aria-hidden="true">
              <lord-icon class="icon-lord" src="https://cdn.lordicon.com/abfverha.json" trigger="hover" colors="primary:#002b44,secondary:#ff9933"></lord-icon>
            </span>
            <strong>24/7</strong>
            <span>متابعة وتشغيل ودعم مستمر</span>
          </article>

          <article class="trustStrip__item" data-tilt>
            <span class="trustStrip__icon" aria-hidden="true">
              <lord-icon class="icon-lord" src="https://cdn.lordicon.com/rsvfayfn.json" trigger="hover" colors="primary:#002b44,secondary:#ff9933"></lord-icon>
            </span>
            <strong>+4</strong>
            <span>سنوات خبرة ميدانية في المملكة</span>
          </article>

          <article class="trustStrip__item" data-tilt>
            <span class="trustStrip__icon" aria-hidden="true">
              <lord-icon class="icon-lord" src="https://cdn.lordicon.com/fikcyfpp.json" trigger="hover" colors="primary:#002b44,secondary:#ff9933"></lord-icon>
            </span>
            <strong>100%</strong>
            <span>التزام واضح بجودة مستوى الخدمة</span>
          </article>
        </div>
      </section>

      <!-- ATEX Overview -->
      <section class="hero" id="atex-overview" aria-label="ATEX Overview">
        <div class="container hero__inner">
          <div class="hero__copy">
            <h1 class="hero__title"><%= content?.hero?.title || "أتكس… مباني أذكى" %></h1>
            <p class="hero__desc">
              <%= content?.hero?.desc || "نحوّل المنازل والفنادق والمباني إلى منظومة متصلة تُظهر لك ما يحدث الآن وتُمكّنك من التحكم بكل التفاصيل بسهولة.\nمن الأجهزة والاتصال إلى المنصة, لتشغيل الإضاءة والتكييف والطاقة والمشاهد، إدارة الغرف والوصول الذكي، ورفع الكفاءة وتقليل التكاليف مع تجربة ضيوف وسكان أكثر رفاهية." %>
            </p>

            <div class="hero__trust" aria-label="مزايا سريعة">
              <div class="pill"><lord-icon class="icon-lord" src="https://cdn.lordicon.com/ueoydrft.json" trigger="hover" colors="primary:#002b44,secondary:#ff9933" aria-hidden="true"></lord-icon> أمان مؤسسي</div>
              <div class="pill"><lord-icon class="icon-lord" src="https://cdn.lordicon.com/hrjifpbq.json" trigger="hover" colors="primary:#002b44,secondary:#ff9933" aria-hidden="true"></lord-icon> تكاملات API</div>
              <div class="pill"><lord-icon class="icon-lord" src="https://cdn.lordicon.com/lenjvibx.json" trigger="hover" colors="primary:#002b44,secondary:#ff9933" aria-hidden="true"></lord-icon> تنفيذ داخل المملكة</div>
            </div>
          </div>

          <!-- Animated scene (GSAP) -->
          <div class="hero__scene" aria-hidden="true">
            <div class="orb orb--a"></div>
            <div class="orb orb--b"></div>
            <div class="orb orb--c"></div>

            <img class="hero__asset hero__asset--ac" src="/assets/hero/ac.png" alt="" loading="lazy" />
            <img class="hero__asset hero__asset--cctv" src="/assets/hero/cctv.png" alt="" loading="lazy" />
            <img class="hero__asset hero__asset--rooms" src="/assets/hero/rooms.png" alt="" loading="lazy" />

            <div class="glass">
              <div class="glass__row">
                <div class="metric">
                  <div class="metric__label">تنبيه</div>
                  <div class="metric__value">درجة حرارة ضمن النطاق</div>
                </div>
                <div class="metric">
                  <div class="metric__label">الحالة</div>
                  <div class="metric__value">الأجهزة متصلة</div>
                </div>
              </div>
              <div class="glass__hint">لوحات متابعة وتنبيهات لحظية</div>
            </div>
          </div>
        </div>
      </section>

      <!-- Solutions -->
      <section class="section" id="solutions">
        <div class="container">
          <div class="section__head">
            <h2>حلول نقدمها</h2>
            <p><%= content?.solutions?.subheading || 'حالات استخدام جاهزة قابلة للتوسع في مشاريع الشركات داخل السعودية.' %></p>
          </div>

          <% const solutionCards = [
            { iconSrc: 'https://cdn.lordicon.com/msoeawqm.json', bg: '/assets/solutions/smart-home.jpg', title: 'أنظمة المنازل الذكية', desc: 'رفاهية، أمان، وكفاءة عبر أتمتة متكاملة للمنزل.' },
            { iconSrc: 'https://cdn.lordicon.com/eszyyflr.json', bg: '/assets/solutions/smart-office.jpg', title: 'أنظمة المكاتب الذكية', desc: 'بيئة عمل ملهمة ومنتِجة مع تحكم ذكي وتشغيل مرن.' },
            { iconSrc: 'https://cdn.lordicon.com/fikcyfpp.json', bg: '/assets/solutions/smart-hotel.jpg', title: 'أنظمة الفنادق الذكية', desc: 'تجربة ضيافة استثنائية مع حلول إدارة وتشغيل حديثة.' },
            { iconSrc: 'https://cdn.lordicon.com/lenjvibx.json', bg: '/assets/solutions/smart-parking.jpg', title: 'أنظمة مواقف السيارات الذكية', desc: 'تنظيم الحركة وتسهيل إدارة المواقف بكفاءة أعلى.' },
            { iconSrc: 'https://cdn.lordicon.com/hrjifpbq.json', bg: '/assets/solutions/smart-building.jpg', title: 'أنظمة إدارة المباني (BMS)', desc: 'تحكم ومراقبة مركزية لأنظمة المبنى لتحسين الأداء.' },
            { iconSrc: 'https://cdn.lordicon.com/dxjqoygy.json', bg: '/assets/solutions/smart-ligting.jpg', title: 'أنظمة إضاءة الواجهات الخارجية', desc: 'حلول إضاءة واجهات احترافية تُبرز الهوية المعمارية.' },
            { iconSrc: 'https://cdn.lordicon.com/rsvfayfn.json', bg: '/assets/solutions/central-vacuum.jpg', title: 'نظام المكنسة المركزية', desc: 'تنظيف أكثر راحة وكفاءة عبر نظام مركزي عملي.' },
            { iconSrc: 'https://cdn.lordicon.com/ueoydrft.json', bg: '/assets/solutions/smart-led-screen.jpg', title: 'شاشات LED الداخلية والخارجية', desc: 'شاشات عرض عالية التأثير للاستخدام الداخلي والخارجي.' },
            { iconSrc: 'https://cdn.lordicon.com/fikcyfpp.json', bg: '/assets/solutions/ev-charging.jpg', title: 'أنظمة شحن المركبات الكهربائية (EV Chargers)', desc: 'بنية شحن موثوقة وقابلة للتوسع للمركبات الكهربائية.' },
            { iconSrc: 'https://cdn.lordicon.com/hrjifpbq.json', bg: '/assets/solutions/ICT-Systems.jpg', title: 'أنظمة تقنية المعلومات والاتصالات ICT Systems', desc: 'بنية اتصالات وشبكات مؤسسية متكاملة تدعم التشغيل الذكي.' },
            { iconSrc: 'https://cdn.lordicon.com/dxjqoygy.json', bg: '/assets/solutions/smart-ligting.jpg', title: 'أنظمة التحكم بالإضاءة الداخلية', desc: 'إدارة ذكية لمشاهد الإضاءة وتوفير الطاقة عبر جداول وأتمتة (DMX - Dali).' },
            { iconSrc: 'https://cdn.lordicon.com/lenjvibx.json', bg: '/assets/solutions/security-Systems.jpg', title: 'الأنظمة الأمنية (Security Systems)', desc: 'مراقبة وحماية متقدمة مع تكامل أنظمة الإنذار والتحكم بالوصول.' }
          ]; %>

          <div class="grid grid--cards">
            <% solutionCards.forEach(function(c){ %>
              <article class="card solutionCard" data-tilt style="--solution-bg:url('<%= c.bg %>')">
                <div class="card__icon">
                  <lord-icon class="icon-lord icon-lord--card" src="<%= c.iconSrc %>" trigger="hover" colors="primary:#002b44,secondary:#ff9933" aria-hidden="true"></lord-icon>
                </div>
                <h3 class="card__title"><%= c.title %></h3>
                <p class="card__desc"><%= c.desc %></p>
              </article>
            <% }) %>
          </div>
        </div>
      </section>

      <!-- Platform section -->
      <section class="section" id="platform">
        <div class="container">
          <div class="platformSection" role="region" aria-label="وصف منصة ATEX">
            <div class="platformSection__bg" aria-hidden="true"></div>
            <div class="platformSection__content">
              <div class="platformSection__kicker"><%= content?.platform?.kicker || 'من جهاز إلى لوحة متابعة خلال وقت قياسي' %></div>
              <h2 class="platformSection__title"><%= content?.platform?.title || 'منصة واحدة للأجهزة والاتصال والبيانات' %></h2>
              <p class="platformSection__desc"><%= content?.platform?.desc || 'نوفّر طبقة إدارة أجهزة، قواعد تنبيهات، لوحات، وتقارير—مع إمكانيات تكامل عبر واجهات برمجية.' %></p>
              <ul class="platformSection__points" aria-label="مزايا المنصة">
                <li><lord-icon class="icon-lord" src="https://cdn.lordicon.com/rsvfayfn.json" trigger="hover" colors="primary:#d97800,secondary:#ff9933" aria-hidden="true"></lord-icon> مراقبة لحظية + تنبيهات فورية</li>
                <li><lord-icon class="icon-lord" src="https://cdn.lordicon.com/rsvfayfn.json" trigger="hover" colors="primary:#d97800,secondary:#ff9933" aria-hidden="true"></lord-icon> تكاملات API مع أنظمة المؤسسة</li>
                <li><lord-icon class="icon-lord" src="https://cdn.lordicon.com/rsvfayfn.json" trigger="hover" colors="primary:#d97800,secondary:#ff9933" aria-hidden="true"></lord-icon> لوحات قابلة للتخصيص لكل فريق</li>
              </ul>
              <div class="platformSection__actions">
                <a class="btn btn--primary" href="#products"><%= content?.platform?.ctaPrimary || 'استكشف المنتجات' %></a>
                <a class="btn btn--ghost" href="#contact"><%= content?.platform?.ctaSecondary || 'ناقش مشروعك' %></a>
              </div>
            </div>
            <div class="platformSection__panel" aria-label="مؤشرات المنصة">
              <div class="platformSection__stats">
                <% (content?.stats || []).forEach(function(s){ %>
                  <div class="stat" data-count="<%= s.value %>">
                    <div class="stat__value"><span class="stat__num"><%= s.value %></span><span class="stat__unit"><%= s.suffix || "" %></span></div>
                    <div class="stat__label"><%= s.label %></div>
                  </div>
                <% }) %>
              </div>
              <div class="platformSection__miniTrend" aria-hidden="true">
                <span></span><span></span><span></span><span></span><span></span><span></span><span></span>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Industries -->
      <section class="section industriesShowcase" id="industries">
        <div class="container">
          <div class="section__head">
            <h2>القطاعات التي نخدمها في المملكة</h2>
            <p>نصمم حلولًا قابلة للتوسع حسب طبيعة كل قطاع لضمان تشغيل ذكي، كفاءة أعلى، وتجربة أفضل.</p>
          </div>

          <div class="industriesShowcase__panel" aria-label="القطاعات المستهدفة">
            <% const industryItems = [
              { label: 'القطاع السكني', bg: '/assets/solutions/smart-home.jpg' },
              { label: 'القطاع التجاري', bg: '/assets/solutions/smart-office.jpg' },
              { label: 'القطاع الحكومي', bg: '/assets/solutions/smart-building.jpg' },
              { label: 'القطاع الصناعي', bg: '/assets/solutions/central-vacuum.jpg' },
              { label: 'قطاع الرعاية الصحية', bg: '/assets/solutions/smart-hotel.jpg' },
              { label: 'قطاع التعليم', bg: '/assets/solutions/smart-led-screen.jpg' },
              { label: 'قطاع المدن الذكية', bg: '/assets/solutions/smart-parking.jpg' }
            ]; %>
            <div class="industriesShowcase__grid">
              <% industryItems.forEach(function(item, idx){ %>
                <article class="industriesShowcase__card" data-tilt style="--industry-bg:url('<%= item.bg %>')">
                  <span class="industriesShowcase__index" dir="ltr"><%= String(idx + 1).padStart(2, '0') %></span>
                  <h3><%= item.label %></h3>
                </article>
              <% }) %>
            </div>

            <div class="industriesShowcase__hint" aria-hidden="true">
              <span>اسحب أفقيًا لاستعراض القطاعات</span>
              <span class="industriesShowcase__hintTrack"><i></i></span>
            </div>

            <div class="industriesShowcase__foot">
              <a class="btn btn--ghost" href="#contact">اطلب استشارة للقطاع المناسب</a>
            </div>
          </div>
        </div>
      </section>

      <!-- Why أتكس -->
      <section class="section" id="why">
        <div class="container">
          <div class="section__head">
            <h2><%= String(content?.why?.heading || 'لماذا أتكس؟').replace(/ATEX/gi, 'أتكس') %></h2>
            <p><%= content?.why?.subheading || 'مزايا تنفيذية واضحة تساعد المطورين وفرق التشغيل على اتخاذ قرار استثماري أسرع وأدق.' %></p>
          </div>

          <% const whyDefaultKeyPoints = [
            { title: 'عائد استثماري قابل للقياس', brief: 'نربط الحلول بمؤشرات تشغيل ووفورات واضحة في الطاقة والصيانة.' },
            { title: 'تنفيذ وتسليم من جهة واحدة', brief: 'نغطي التصميم، التوريد، التنفيذ، الاختبارات، والتشغيل المبدئي.' },
            { title: 'تكامل جاهز مع الأنظمة الحالية', brief: 'ربط مرن مع BMS وأنظمة الأمن والتحكم بالوصول دون تعقيد تشغيلي.' },
            { title: 'دعم تشغيلي محلي طويل المدى', brief: 'فرق فنية داخل المملكة مع SLA واضحة وخطة صيانة مستمرة.' }
          ]; %>
          <% const whyContentCards = Array.isArray(content?.why?.cards) ? content.why.cards : []; %>
          <% const whyLegacyTitles = ['أمان مؤسسي', 'تكاملات سريعة', 'نتائج أسرع']; %>
          <% const whyIsLegacy = whyContentCards.length > 0 && whyContentCards.every(function(c){ return whyLegacyTitles.includes(String(c?.title || '')); }); %>
          <% const whyKeyPoints = (whyContentCards.length ? whyContentCards.map(function(c){
            return {
              title: c?.title || '',
              brief: c?.desc || ''
            };
          }) : whyDefaultKeyPoints); %>
          <% const whyFinalPoints = (whyIsLegacy ? whyDefaultKeyPoints : whyKeyPoints).slice(0, 4).filter(function(p){ return p.title || p.brief; }); %>

          <div class="whyKeypoints" role="list" aria-label="أسباب اختيار أتكس">
            <% whyFinalPoints.forEach(function(point, idx){ %>
              <article class="whyKeypoints__item" role="listitem" data-tilt>
                <span class="whyKeypoints__index" dir="ltr"><%= String(idx + 1).padStart(2, '0') %></span>
                <h3><%= point.title %></h3>
                <p><%= point.brief %></p>
              </article>
            <% }) %>
          </div>
        </div>
      </section>

      <!-- How we work (flow chart) -->
      <section class="section" id="process">
        <div class="container">
          <div class="section__head">
            <h2>كيف نعمل</h2>
            <p>خطوات واضحة من الفكرة إلى التشغيل ثم التحسين المستمر.</p>
          </div>

          <% const processDefaultSteps = [
            { title: 'تحليل حالة الاستخدام', desc: 'تعريف الهدف، المؤشرات، نطاق الأجهزة، ومتطلبات التكامل.' },
            { title: 'اختيار الأجهزة والاتصال', desc: 'ترشيح الحساسات/الأجهزة والبروتوكولات المناسبة للبيئة.' },
            { title: 'التركيب والتهيئة', desc: 'تركيب ميداني، إعداد تنبيهات أولية، واختبارات قبول.' },
            { title: 'لوحات وتقارير', desc: 'لوحات تشغيلية وتقارير دورية للمديرين وفرق العمليات.' },
            { title: 'تحسين مستمر', desc: 'تحسين القواعد، تقليل الإنذارات الخاطئة، وتوسيع النطاق.' }
          ]; %>
          <% const processSteps = processDefaultSteps; %>
          <ol class="processFlow" aria-label="مخطط تدفق خطوات التنفيذ">
            <% processSteps.forEach(function(s, idx){ %>
              <li class="processFlow__item">
                <span class="processFlow__stepNo" dir="ltr"><%= String(idx + 1).padStart(2, '0') %></span>
                <h3 class="processFlow__title"><%= s.title %></h3>
                <p class="processFlow__desc"><%= s.desc %></p>
                <% if (idx < processSteps.length - 1) { %>
                  <span class="processFlow__arrow" aria-hidden="true">←</span>
                <% } %>
              </li>
            <% }) %>
          </ol>
        </div>
      </section>

      <!-- Integrations marquee -->
      <section class="section" id="integrations">
        <div class="container">
          <div class="section__head">
            <h2>تقنيات السمارت التي ندعمها</h2>
            <p>منصات وتقنيات الاتصال والتكامل والتحليلات المستخدمة في حلول إنترنت الأشياء.</p>
          </div>

          <% const defaultChips = ['Wi-Fi 7', 'WPA3', 'بلوتوث 5.4', 'Zigbee 3.0', 'Thread 1.4', 'Matter 1.5', 'LoRaWAN 1.1', 'NB-IoT', 'LTE-M / eMTC', 'MQTT 5.0', 'CoAP 1.0', 'HTTP/3', 'QUIC v1', 'RTSP 2.0', 'PoE IEEE 802.3bt', 'TLS 1.3']; %>
          <% const chips = (Array.isArray(content?.integrations?.chips) ? content.integrations.chips : defaultChips).map(function(c){ return String(c || '').trim(); }).filter(Boolean); %>
          <div class="marquee" data-marquee aria-label="شريط تكاملات">
            <div class="marquee__viewport" data-marquee-viewport>
              <div class="marquee__runner" data-marquee-runner>
                <div class="marquee__content" data-marquee-content>
                  <% chips.forEach(function(label){ %>
                    <span class="marquee__text"><%= label %></span>
                    <span class="marquee__sep" aria-hidden="true">|</span>
                  <% }) %>
                </div>
                <div class="marquee__content" data-marquee-static-clone aria-hidden="true">
                  <% chips.forEach(function(label){ %>
                    <span class="marquee__text"><%= label %></span>
                    <span class="marquee__sep" aria-hidden="true">|</span>
                  <% }) %>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- FAQ -->
      <section class="section" id="faq">
        <div class="container">
          <div class="section__head">
            <h2><%= content?.faq?.heading || 'أسئلة شائعة' %></h2>
            <p><%= content?.faq?.subheading || 'إجابات مختصرة لأسئلة المطورين العقاريين قبل اعتماد الحل.' %></p>
          </div>

          <% const faqDefaults = [
            { q: 'كيف نقيس العائد الاستثماري (ROI) قبل التعميم؟', a: 'نبدأ بنطاق واضح للمشروع ونحدد مؤشرات قابلة للقياس مثل خفض استهلاك الطاقة وتقليل الأعطال وسرعة الاستجابة التشغيلية، ثم نعرض نتائج دورية تساعدكم في قرار التوسع.' },
            { q: 'ما متطلبات الموقع والجدول الزمني للتنفيذ؟', a: 'نعتمد خطة تنفيذ مرتبطة بمرحلة المشروع، تشمل الجاهزية الكهربائية والشبكية ونقاط التركيب، مع جدول زمني واضح للتوريد والتركيب والاختبار والتسليم.' },
            { q: 'ما الضمان ومستوى الدعم بعد التسليم؟', a: 'نقدم ضماناً على المكونات وخطة دعم ما بعد البيع تشمل الصيانة الوقائية والتصحيحية مع اتفاقية مستوى خدمة (SLA) حسب احتياج المشروع.' },
            { q: 'هل يمكن التكامل مع الأنظمة الحالية مثل BMS وCCTV والتحكم بالوصول؟', a: 'نعم، الحل مصمم للتكامل التدريجي مع الأنظمة القائمة لتقليل إعادة العمل وضمان استمرارية التشغيل دون تعطيل.' },
            { q: 'هل يمكن التوسع على عدة مبانٍ أو مراحل تطوير؟', a: 'بكل تأكيد، التصميم قابل للتوسع من مبنى واحد إلى محفظة مشاريع كاملة مع حوكمة مركزية وصلاحيات تشغيل مناسبة لكل موقع.' },
            { q: 'كيف تتم إدارة خصوصية البيانات وصلاحيات الوصول؟', a: 'يتم تطبيق سياسات وصول حسب الأدوار مع سجلات تدقيق واضحة، بما يضمن حماية البيانات وإتاحة المعلومات للجهات المخولة فقط.' },
            { q: 'كيف يتم تسليم التشغيل لفريق إدارة المرافق (FM)؟', a: 'نوفر خطة Handover تشمل التوثيق، التدريب العملي، وإجراءات التشغيل القياسية لضمان انتقال سلس للفريق التشغيلي.' },
            { q: 'ماذا يحدث عند انقطاع الشبكة أو ضعف الاتصال؟', a: 'يستمر النظام في تشغيل الوظائف الأساسية محلياً وفق تصميم المشروع، مع مزامنة البيانات والتنبيهات تلقائياً عند عودة الاتصال.' }
          ]; %>
          <% const faqLegacyQuestions = [
            'هل يمكن تنفيذ الحل داخل السعودية؟',
            'هل تدعمون التكامل مع أنظمتنا؟',
            'هل يمكن البدء بمرحلة تجريبية؟'
          ]; %>
          <% const faqContentItems = Array.isArray(content?.faq?.items) ? content.faq.items : []; %>
          <% const faqIsLegacy = faqContentItems.length > 0 && faqContentItems.every(function(i){ return faqLegacyQuestions.includes(String(i?.q || '')); }); %>
          <% const faqItems = (faqContentItems.length && !faqIsLegacy) ? faqContentItems : faqDefaults; %>

          <div class="faq" role="list">
            <% faqItems.forEach(function(it){ %>
              <div class="faq__item" role="listitem">
                <button class="faq__q" type="button"><%= it.q %> <span class="faq__icon">+</span></button>
                <div class="faq__a"><%= it.a %></div>
              </div>
            <% }) %>
          </div>
        </div>
      </section>

      <% const showProductsSection = content?.sections?.productsEnabled !== false; %>
      <% if (showProductsSection) { %>
        <!-- Products (rendered from JSON/API later) -->
        <section class="section" id="products">
          <div class="container">
            <div class="section__head">
              <h2>منتجات جاهزة للتوسّع</h2>
              <p>منتجات يتم إدارتها مباشرة من لوحة التحكم مع إمكانية النشر والإخفاء.</p>
            </div>
            <div class="grid grid--products" id="productsGrid" aria-live="polite"></div>
          </div>
        </section>
      <% } %>

      <!-- Blog teaser -->
      <section class="section" id="blog">
        <div class="container">
          <div class="section__head">
            <h2><%= content?.blogTeaser?.heading || 'المدونة' %></h2>
            <p><%= content?.blogTeaser?.subheading || 'آخر المقالات وأفضل الممارسات في إنترنت الأشياء.' %></p>
          </div>

          <% if ((latestPosts || []).length) { %>
            <div class="grid grid--posts" aria-label="آخر المقالات">
              <% latestPosts.forEach(function(p){ %>
                <article class="item" data-tilt>
                  <div class="item__media">
                    <% if (p.cover_image) { %>
                      <img src="<%= p.cover_image %>" alt="<%= p.title %>" loading="lazy" />
                    <% } %>
                  </div>
                  <div class="item__body">
                    <div class="item__tag" dir="ltr">/<%= p.slug %></div>
                    <h3 class="item__title"><%= p.title %></h3>
                    <p class="item__desc"><%= p.excerpt || '' %></p>
                    <div class="item__actions">
                      <a class="btn btn--primary btn--small" href="/blog/<%= p.slug %>">اقرأ المزيد</a>
                      <a class="btn btn--ghost btn--small" href="/blog">كل المقالات</a>
                    </div>
                  </div>
                </article>
              <% }) %>
            </div>
          <% } else { %>
            <div class="item" style="padding:16px">
              <p style="margin:0; font-weight:800">لا توجد مقالات منشورة حالياً. يمكنك نشر مقالات من لوحة الإدارة.</p>
              <div style="margin-top:10px">
                <a class="btn btn--primary btn--small" href="<%= content?.blogTeaser?.ctaHref || '/blog' %>"><%= content?.blogTeaser?.ctaText || 'فتح المدونة' %></a>
              </div>
            </div>
          <% } %>
        </div>
      </section>

      <!-- Social proof -->
      <section class="section socialProof" id="social-proof">
        <div class="container">
          <div class="section__head">
            <h2>موثوقية مثبتة في السوق</h2>
            <p>شركاؤنا وعملاؤنا في السعودية يعتمدون على أتكس في تنفيذ مشاريع ذكية بمعايير تشغيل عالية.</p>
          </div>

          <div class="socialProof__logos marquee" data-marquee aria-label="شعارات شركات سعودية">
            <div class="marquee__viewport" data-marquee-viewport>
              <div class="marquee__runner" data-marquee-runner>
                <div class="marquee__content" data-marquee-content>
                  <% (Array.isArray(socialLogos) ? socialLogos : []).forEach(function(logoPath, i){ %>
                    <div class="socialProof__logo" aria-label="شريك <%= i + 1 %>">
                      <img src="<%= logoPath %>" alt="شعار الشريك <%= i + 1 %>" loading="lazy" />
                    </div>
                  <% }) %>
                </div>

                <div class="marquee__content" data-marquee-static-clone aria-hidden="true">
                  <% (Array.isArray(socialLogos) ? socialLogos : []).forEach(function(logoPath){ %>
                    <div class="socialProof__logo">
                      <img src="<%= logoPath %>" alt="" loading="lazy" />
                    </div>
                  <% }) %>
                </div>
              </div>
            </div>
          </div>

          <div class="grid grid--cards quotesGrid">
            <article class="card quoteCard" data-tilt>
              <h3 class="card__title">"تنفيذ احترافي وسرعة استجابة ممتازة"</h3>
              <p class="card__desc">مدير مشروع – قطاع الضيافة</p>
            </article>
            <article class="card quoteCard" data-tilt>
              <h3 class="card__title">"تحسن واضح في كفاءة التشغيل بعد التكامل"</h3>
              <p class="card__desc">مدير تشغيل – قطاع العقارات</p>
            </article>
            <article class="card quoteCard" data-tilt>
              <h3 class="card__title">"فريق داعم وخطة تنفيذ واضحة من البداية"</h3>
              <p class="card__desc">مالك مشروع – قطاع سكني</p>
            </article>
          </div>
        </div>
      </section>

      <!-- Final CTA -->
      <section class="section finalCta" id="contact" aria-label="دعوة للتواصل">
        <div class="container">
          <div class="finalCta__band">
            <div class="finalCta__main">
              <h2><%= content?.contact?.heading || 'جاهز لبدء مشروعك؟' %></h2>
              <p><%= content?.contact?.subheading || 'أرسل لنا استفسارك والفريق الفني سيقدم (حلول + أجهزة + تكامل) مع خطة تنفيذ واضحة.' %></p>
              <a class="btn btn--primary" href="https://wa.me/966580102121" target="_blank" rel="noopener noreferrer">تواصل واتساب الآن</a>
            </div>

            <div class="finalCta__card" aria-label="حلول عند الطلب">
              <h3>هنالك دائماً حل عند الطلب</h3>
              <p>إذا لم تجد ما تبحث عنه، يمكنك الاتصال بنا مباشرة وسنقدّم لك استشارة مجانية لمساعدتك في اختيار الحل الأنسب.</p>
              <a class="btn btn--ghost" href="tel:+966580102121" dir="ltr">+966 58 010 2121</a>
            </div>
          </div>
        </div>
      </section>
    </main>

    <%- include('partials/site-footer') %>
  </body>
</html>
